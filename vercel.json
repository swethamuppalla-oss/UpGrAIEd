{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "server/api/index.js": {
      "includeFiles": "server/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server/api/index.js" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
