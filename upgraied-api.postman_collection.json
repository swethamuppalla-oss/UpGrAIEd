{
  "info": {
    "name": "UpgrAIed API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://upgraied-backend.onrender.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Test DB",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/test-db",
            "header": []
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": "{{base_url}}/api/test-db"
              },
              "body": "{\"message\": \"DB connected\"}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/admin-login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "POST",
                "url": "{{base_url}}/api/auth/admin-login",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
                }
              },
              "body": "{\"token\": \"<jwt>\", \"user\": {\"role\": \"admin\"}}"
            }
          ]
        },
        {
          "name": "Demo Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/demo-login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"student\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "POST",
                "url": "{{base_url}}/api/auth/demo-login",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"role\": \"student\"\n}"
                }
              },
              "body": "{\"token\": \"<jwt>\", \"user\": {\"role\": \"student\"}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Student",
      "item": [
        {
          "name": "Get Progress",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/student/progress",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/student/stats",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Get Levels",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/student/levels",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Get Curriculum",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/student/curriculum",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": []
        }
      ]
    },
    {
      "name": "Video",
      "item": [
        {
          "name": "Get Stream URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/videos/{{moduleId}}/stream-url",
              "host": ["{{base_url}}"],
              "path": ["api", "videos", "{{moduleId}}", "stream-url"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": "{{base_url}}/api/videos/module123/stream-url",
                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
              },
              "body": "{\"url\": \"https://cdn.example.com/video/stream.m3u8\"}"
            }
          ]
        }
      ]
    }
  ]
}
